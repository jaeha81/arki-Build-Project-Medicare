# Project Medicare — Environment Variables Template
# Copy this file to .env.local (frontend) or .env (backend) and fill in values.
# NEVER commit .env files to git.

# ── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/medicare

# ── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── AI ────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Email ─────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── Frontend ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Admin (dev stub — replace with Supabase Auth in production) ───────────
ADMIN_DEV_EMAIL=admin@medicare.dev
ADMIN_DEV_PASSWORD=admin1234
ADMIN_API_TOKEN=dev-admin-token-placeholder

# ── Backend ───────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
DEBUG=true

# ── Allowed Origins (comma-separated) ─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# ── Vercel / Railway production overrides ─────────────────────────────────
# Set these in the respective platform dashboards — never commit real values.
# Vercel secret names (prefix with @) must match vercel.json env block.
# NEXT_PUBLIC_API_URL=https://api.medicare.railway.app
# NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
